<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- Variables -->
  <xacro:property name="wheel_radius" value="0.0425" />
  <xacro:property name="wheel_width" value="0.04" />
  <xacro:property name="wheel_gap" value="0.009" />

  <!-- Wheel Macro -->
  <xacro:macro name="wheel" params="prefix parent x y z rotation">
    <joint name="${prefix}_wheel_joint" type="continuous">
      <parent link="${parent}"></parent>
      <child link="${prefix}_wheel"></child>
      <origin xyz="${x} ${y} ${z}" rpy="${rotation * pi/2} 0 0" />
      <axis xyz="0 0 ${rotation * -1}" />
    </joint>

    <link name="${prefix}_wheel">
      <visual>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <mesh filename="${mesh_path}/wheel.stl"/>
          <!-- <mesh filename="/home/subham/ros_ws/diff_drive/src/diff_bot_description/meshes/wheel.stl" scale="1 1 1"/> -->
        </geometry>
        <material name="black"/>
      </visual>
      <collision>
        <origin xyz="0 0 -0.02"/>
        <geometry>
           <sphere radius="${wheel_radius}"/>
        </geometry>
      </collision>
      <xacro:inertial_cylinder mass="0.1" radius="${wheel_radius}" length="${wheel_width}">
        <origin xyz="0 0 0"/>
      </xacro:inertial_cylinder>
    </link> 
  </xacro:macro>

  <!-- Wheels -->
  <xacro:wheel prefix="bottom_left" parent="chassis" x="0.0" y="0.21" z="0.0" rotation="1"/>
  <xacro:wheel prefix="bottom_right" parent="chassis" x="0.0" y="-0.21" z="0.0" rotation="-1"/>

</robot>
